{
  "name": "4d-art-generation",
  "version": "0.1.0",
  "type": "module",
  "description": "4D Art - 4D Pixel Matrix Generator",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleFileExtensions": [
      "js",
      "mjs"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/utils/**/*.js",
      "!js/main.js",
      "!js/app.js",
      "!js/render/renderer.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./js/utils/hash.js": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "coverageDirectory": "coverage"
  },
  "keywords": [
    "4d",
    "art",
    "generator",
    "three.js",
    "webgl"
  ],
  "author": "",
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robinyst-alt/4d-art-generation.git"
  },
  "bugs": {
    "url": "https://github.com/robinyst-alt/4d-art-generation/issues"
  },
  "homepage": "https://github.com/robinyst-alt/4d-art-generation#readme",
  "devDependencies": {
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "playwright": "^1.60.0",
    "three": "^0.160.0"
  },
  "dependencies": {
    "canvas": "^3.2.3"
  }
}
